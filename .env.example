# Local development
DATABASE_URL="file:./dev.db"
LOCAL_ADMIN_EMAIL=admin@echosante.org
LOCAL_ADMIN_PASSWORD=password
AUTH_COOKIE_SECRET=change-me-in-production

# Production: set DATABASE_URL to your Supabase Postgres connection string.
# Example:
# DATABASE_URL="postgresql://<username>:<password>@<host>:5432/postgres?schema=public"

# Supabase auth environment variables used by the frontend and server code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
