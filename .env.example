# # Local development with SQLite
# DATABASE_URL="file:./dev.db"
# LOCAL_ADMIN_EMAIL=admin@echosante.org
# LOCAL_ADMIN_PASSWORD=password
# AUTH_COOKIE_SECRET=replace-with-a-random-32-char-minimum-secret
# SITE_URL=http://localhost:3000

# # Supabase public variables, exposed to browser code.
# # Leave empty for SQLite/mock development. Fill them to test Supabase locally.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# # Supabase server variables. Never expose SUPABASE_SERVICE_KEY in browser code.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_ANON_KEY=

