{
  "name": "echo-sante-ngosite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run prisma:generate:sqlite && npm run prisma:push:sqlite && npm run prisma:seed && next dev",
    "dev:mock": "TEST_SUPABASE=1 next dev",
    "build": "if [ \"$NODE_ENV\" != \"production\" ]; then npm run prisma:generate:sqlite; else npm run prisma:generate; fi && next build",
    "build:local": "npm run prisma:generate:sqlite && DATABASE_URL=file:./dev.db DEBUG=true next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "prisma:push:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:migrate": "prisma migrate deploy",
    "test:mock": "node scripts/test-flows.js",
    "test:integration": "tsx scripts/test-flows-real.ts",
    "migrate:supabase": "tsx scripts/migrate-to-supabase.mjs",
    "env:check": "node scripts/check-supabase-env.mjs --target=production",
    "env:check:local": "node scripts/check-supabase-env.mjs --target=local",
    "env:check:live": "node scripts/check-supabase-env.mjs --target=production --live"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@supabase/supabase-js": "^2.35.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.64.0",
    "sonner": "^2.0.7",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.40",
    "@types/react-dom": "^19.0.17",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.13",
    "prisma": "^5.17.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.13"
    }
  }
}
