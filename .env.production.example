# Production environment variables for Vercel.
# Copy each placeholder value to Vercel Project Settings > Environment Variables.
# NEVER commit real values to git.

NODE_ENV=production
SITE_URL=https://echosanteunigome.vercel.app

# Supabase PostgreSQL Connection (PgBouncer for pooling)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Supabase PostgreSQL Direct Connection (for migrations only)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Supabase REST API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_URL=https://[project-ref].supabase.co

# Supabase Authentication Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_[token]
SUPABASE_ANON_KEY=sb_publishable_[token]
SUPABASE_SERVICE_KEY=sb_secret_[token]

# Session Management
AUTH_COOKIE_SECRET=[generate-using: openssl rand -base64 32]

# Supabase Storage Bucket
SUPABASE_STORAGE_BUCKET=echosante
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=echosante



