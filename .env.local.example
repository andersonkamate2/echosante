# Local Supabase development override.
# Copy to .env.local only when you want local Next.js to use Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Required when local admin API routes should use Supabase PostgreSQL through Prisma.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=public"
AUTH_COOKIE_SECRET=replace-with-a-random-32-char-minimum-secret
SITE_URL=http://localhost:3000
